<% content_for :title, "Todos" %>
<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold text-gray-900">Todos</h1>
  <%= link_to "New todo", new_todo_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
</div>
<div class="mb-4">
  <%= form_with url: todos_path, method: :get, local: true, class: "flex items-end space-x-3" do %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Filter by project</label>
      <%= select_tag :project_id,
            options_for_select([["All", "all"]] + @projects.map { |p| [p.name, p.id] }, selected: @project_id || "all"),
            include_blank: false,
            class: "block w-64 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    </div>
    <div>
      <%= submit_tag "Apply", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      <%= link_to "Reset", todos_path, class: "ml-2 inline-block bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  <% end %>
</div>
<div class="bg-white shadow overflow-hidden sm:rounded-md">
  <% if @todos.any? %>
    <ul class="divide-y divide-gray-200" id="todos">
      <% @todos.each do |todo| %>
        <li class="px-6 py-4 hover:bg-gray-50">
          <%= render todo, truncate: true %>
          <div class="mt-3">
            <%= link_to "Show this todo", todo, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="px-6 py-4 border-t border-gray-200">
      <%= paginate @todos %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-500 text-lg">No todos yet.</p>
      <%= link_to "Create your first todo", new_todo_path, class: "mt-4 inline-block bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  <% end %>
</div>
