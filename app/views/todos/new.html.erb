<% content_for :title, "New todo" %>

<div class="max-w-md mx-auto bg-white shadow-lg rounded-lg p-6">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Todo</h1>

  <%= render "form", todo: @todo %>

  <div class="mt-6">
    <%= link_to "← Back to todos", todos_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>
