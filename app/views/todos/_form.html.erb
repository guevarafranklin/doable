<%= form_with(model: todo, class: "space-y-6") do |form| %>
  <% if todo.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <h2 class="text-lg font-medium text-red-800 mb-2">
        <%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:
      </h2>
      <ul class="list-disc list-inside text-red-700">
        <% todo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :name, 
        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>
  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_area :description, rows: 3,
        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
  </div>
  <div class="flex items-center">
    <%= form.check_box :completed, 
        class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
    <%= form.label :completed, "Mark as completed", class: "ml-2 block text-sm text-gray-900" %>
  </div>
  <div>
    <%= form.label :priority, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.number_field :priority, in: 1..5, 
        class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
    <p class="mt-1 text-sm text-gray-500">Priority from 1 (low) to 5 (high)</p>
  </div>
  <div>
    <%= form.label :project_id, "Project", class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.collection_select :project_id, Project.all, :id, :name, 
        { prompt: "Select a project" }, 
        { class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
  </div>
  <div>
    <%= form.submit class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
<% end %>
