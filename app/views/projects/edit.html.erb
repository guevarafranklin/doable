<% content_for :title, "Editing project" %>
<div class="max-w-md mx-auto bg-white shadow-lg rounded-lg p-6">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Editing Project</h1>
  <%= render "form", project: @project %>
  <div class="mt-6 flex space-x-3">
    <%= link_to "Show this project", @project, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    <%= link_to "Back to projects", projects_path, class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>